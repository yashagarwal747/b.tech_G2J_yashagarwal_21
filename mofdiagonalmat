#include <stdio.h>

int main() {
    int n;

    printf("Enter the size of the square matrix: ");
    scanf("%d", &n);

    int matrix[n][n];
    printf("Enter elements of the matrix:\n");
    for(int i = 0; i < n; i++) {
        for(int j = 0; j < n; j++) {
            printf("Element [%d][%d]: ", i, j);
            scanf("%d", &matrix[i][j]);
        }
    }

    int sum = 0;
    for(int i = 0; i < n; i++) {
        sum += matrix[i][i];          
        sum += matrix[i][n - 1 - i];   
    }
    if(n % 2 != 0) {
        sum -= matrix[n/2][n/2];
    }

    printf("Sum of all diagonal elements = %d\n", sum);

    return 0;
}
